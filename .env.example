# Database
DATABASE_URL="postgresql://username:password@localhost:5432/pdf_tools"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Stripe Payment Integration (Global)
STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# Razorpay Payment Integration (India/UPI)
RAZORPAY_KEY_ID="rzp_test_your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# Google AdSense
GOOGLE_ADSENSE_CLIENT_ID="ca-pub-your-adsense-client-id"
GOOGLE_ADSENSE_SLOT_ID="your-ad-slot-id"

# File Processing
FILE_UPLOAD_SIZE_LIMIT_MB=50
PREMIUM_FILE_UPLOAD_SIZE_LIMIT_MB=500
MAX_CONCURRENT_UPLOADS=5
PREMIUM_MAX_CONCURRENT_UPLOADS=25

# Redis for Queue/Cache (Optional)
REDIS_URL="redis://localhost:6379"

# Email Service (for notifications)
EMAIL_SERVICE_API_KEY="your_email_service_api_key"
EMAIL_FROM="noreply@yourpdftools.com"

# Analytics
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
MIXPANEL_TOKEN="your_mixpanel_token"

# Feature Flags
ENABLE_OCR="true"
ENABLE_COLLABORATION="false"
ENABLE_API="false"

# Security
ENCRYPTION_KEY="your-32-character-encryption-key"
JWT_SECRET="your-jwt-secret-key"

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
PREMIUM_RATE_LIMIT_REQUESTS_PER_MINUTE=300